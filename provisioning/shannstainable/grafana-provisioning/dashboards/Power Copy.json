          "query": "SELECT mean(\"value\") FROM \"power\" WHERE (\"sensorName\" = 'Imported' OR \"sensorName\" = 'Consumed' OR \"sensorName\" = 'HWS' OR \"sensorName\" = 'Car') AND $timeFilter GROUP BY time($__interval), \"sensorName\" fill(linear)",
