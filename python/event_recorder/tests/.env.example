# Event Recorder Environment Variables
# Copy this file to .env and configure with your values

# WordPress Site Configuration
# =============================
# Your WordPress site URL (include https://)
WP_SITE_URL=https://yourblog.com

# Your WordPress username (usually "admin" or your display name)
WP_USERNAME=admin

# WordPress Application Password
# Generate at: WordPress Admin → Users → Profile → Application Passwords
# Format: Keep the spaces! Example: "xxxx xxxx xxxx xxxx xxxx xxxx"
WP_APP_PASSWORD="your app password here with spaces"

# Optional: Additional WordPress Sites
# WP_ALT_SITE_URL=https://alternate-blog.com
# WP_ALT_USERNAME=admin
# WP_ALT_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# MQTT Configuration (if different from defaults)
# MQTT_BROKER=mqtt
# MQTT_PORT=1883

# Database Path (if different from default)
# DATABASE_PATH=/data/recordings.db

# Timezone (default: Australia/Perth)
# TIMEZONE=Australia/Perth

# Development Settings
# DEBUG=false
# WEB_PORT=5000

# =============================
# SECURITY NOTES
# =============================
# - NEVER commit .env file to git
# - Application passwords are safer than main WordPress password
# - Revoke unused application passwords regularly
# - Use HTTPS for WordPress site (required for app passwords)
# - Keep this file secure with proper permissions (chmod 600 .env)
