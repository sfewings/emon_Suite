{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "exportCSV - all sensors",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/python/exportCSV/export_csv.py",
            "args": [
                "--start", "2026-03-23 17:00:00",
                "--end", "2026-03-24 23:59:59",
                "--log-folder", "${workspaceFolder}/python/exportCSV/tests/data",
                "--settings-folder", "${workspaceFolder}/python/exportCSV/tests/data/emon_config",
                "--output", "${workspaceFolder}/python/exportCSV/tests/export_output.csv"
            ],
            "cwd": "${workspaceFolder}/python/exportCSV",
            "console": "integratedTerminal"
        },
        {
            "name": "exportCSV - with config file",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/python/exportCSV/export_csv.py",
            "args": [
                "--start", "2026-03-23 17:00:00",
                "--end", "2026-03-24 23:59:59",
                "--log-folder", "${workspaceFolder}/python/exportCSV/tests/data",
                "--settings-folder", "${workspaceFolder}/python/exportCSV/tests/data/emon_config",
                "--config", "${workspaceFolder}/python/exportCSV/tests/export_config_example.yml",
                "--output", "${workspaceFolder}/python/exportCSV/tests/export_output.csv"
            ],
            "cwd": "${workspaceFolder}/python/exportCSV",
            "console": "integratedTerminal"
        },
        {
            "name": "exportCSV - list sensors",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/python/exportCSV/export_csv.py",
            "args": [
                "--list-sensors",
                "--settings-folder", "${workspaceFolder}/python/exportCSV/tests/data/emon_config"
            ],
            "cwd": "${workspaceFolder}/python/exportCSV",
            "console": "integratedTerminal"
        }
    ]
}
